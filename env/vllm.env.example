# Copy this to /workspace/ops/vllm.env and fill values.

# Base paths
WORKSPACE_DIR=/workspace
APP_ROOT=/workspace/services/vllm-deployment

# Network
# Keep SUPERVISOR_UI_HOST as 127.0.0.1 (do not expose Supervisor directly).
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
SUPERVISOR_UI_HOST=127.0.0.1
SUPERVISOR_UI_PORT=9000

# vLLM model settings
CUDA_VISIBLE_DEVICES=0
VLLM_MODEL=Qwen/Qwen3.5-9B
SERVED_MODEL_NAME=qwen3.5-9b
VLLM_DTYPE=auto
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=32768
TRUST_REMOTE_CODE=false
EXTRA_VLLM_ARGS=

# REQUIRED: set a strong key before production use.
VLLM_API_KEY=replace-with-long-random-token

# Supervisor UI auth (bind remains localhost)
SUPERVISOR_UI_USER=admin
SUPERVISOR_UI_PASS=replace-with-strong-password
