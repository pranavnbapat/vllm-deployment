# Copy this to /workspace/ops/runpod.env and fill values.

# Base paths
WORKSPACE_DIR=/workspace
APP_ROOT=/workspace/services/vllm-deployment

# Network
# Keep SUPERVISOR_UI_HOST as 127.0.0.1 (do not expose Supervisor directly).
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
SUPERVISOR_UI_HOST=127.0.0.1
SUPERVISOR_UI_PORT=9000

# vLLM model settings
CUDA_VISIBLE_DEVICES=0
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
SERVED_MODEL_NAME=qwen2.5-7b
VLLM_DTYPE=auto
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=32768
TRUST_REMOTE_CODE=false
EXTRA_VLLM_ARGS=

# REQUIRED: set a strong key before production use.
VLLM_API_KEY=replace-with-long-random-token

# Supervisor UI auth (bind remains localhost)
SUPERVISOR_UI_USER=admin
SUPERVISOR_UI_PASS=replace-with-strong-password

# Optional media_transcriber service
ENABLE_MEDIA_TRANSCRIBER=false
MEDIA_REPO_URL=
MEDIA_REPO_DIR=/workspace/services/media_transcriber
MEDIA_PORT=8005
BASIC_USER=
BASIC_PASS=
